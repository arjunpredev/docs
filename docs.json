{
	"$schema": "https://mintlify.com/docs.json",
	"theme": "mint",
	"name": "pre.dev",
	"appearance": {
		"default": "dark"
	},
	"colors": {
		"primary": "#000000",
		"light": "#FFFFFF",
		"dark": "#333333"
	},
	"favicon": "https://pre.dev/favicon.ico",
	"api": {
		"baseUrl": "https://api.pre.dev",
		"auth": {
			"method": "bearer",
			"name": "Authorization"
		},
		"playground": {
			"mode": "show"
		},
		"maintainOrder": true
	},
	"openapi": ["api-reference/openapi.json"],
	"navigation": {
		"tabs": [
			{
				"tab": "Platform",
				"groups": [
					{
						"group": "Getting Started",
						"pages": [
							"what-is-predev",
							"quickstart",
							"how-it-works"
						]
					},
					{
						"group": "Projects",
						"pages": [
							"projects/creating-a-project",
							"projects/importing-repos"
						]
					},
					{
						"group": "Specifications",
						"pages": [
							"specifications/understanding-specs",
							"specifications/fast-vs-deep"
						]
					},
					{
						"group": "Building",
						"pages": [
							"building/build-modes",
							"building/acceptance-criteria",
							"building/pull-requests",
							"building/progress-tracking"
						]
					},
					{
						"group": "Knowledge Base",
						"pages": [
							"knowledge-base/overview"
						]
					}
				]
			},
			{
				"tab": "API & MCP",
				"groups": [
					{
						"group": "Overview",
						"pages": [
							"api-mcp/overview",
							"mcp-server"
						]
					},
					{
						"group": "API Reference",
						"pages": [
							"api-reference/introduction",
							"api-reference/overview",
							"api-reference/fast-spec",
							"api-reference/deep-spec",
							"api-reference/list-specs",
							"api-reference/find-specs",
							"api-reference/spec-status",
							"api-reference/credits-balance"
						]
					},
					{
						"group": "SDKs",
						"pages": ["sdks/overview", "sdks/python", "sdks/node"]
					}
				]
			},
			{
				"tab": "Guides",
				"groups": [
					{
						"group": "Best Practices",
						"pages": [
							"guides/use-cases",
							"guides/integration-patterns",
							"guides/best-practices",
							"guides/documentation-scraping"
						]
					}
				]
			}
		],
		"global": {
			"anchors": [
				{
					"anchor": "Create a Project",
					"href": "https://pre.dev",
					"icon": "plus"
				},
				{
					"anchor": "Dashboard",
					"href": "https://pre.dev/projects",
					"icon": "grid-2"
				},
				{
					"anchor": "API Playground",
					"href": "https://pre.dev/projects/playground",
					"icon": "code"
				},
				{
					"anchor": "Blog",
					"href": "https://pre.dev/blog",
					"icon": "newspaper"
				},
				{
					"anchor": "Community",
					"href": "https://discord.com/invite/ejVTRJ6WXS",
					"icon": "discord"
				}
			]
		}
	},
	"logo": {
		"light": "https://pre.dev/predev_logo_name_white.png",
		"dark": "https://pre.dev/predev_logo_name.png"
	},
	"navbar": {
		"links": [
			{
				"label": "pre.dev",
				"href": "https://pre.dev"
			}
		],
		"primary": {
			"type": "button",
			"label": "Start Building",
			"href": "https://pre.dev"
		},
		"logoHeight": "60px"
	},
	"contextual": {
		"options": [
			"copy",
			"view",
			"chatgpt",
			"claude",
			"perplexity",
			"mcp",
			"cursor",
			"vscode"
		]
	},
	"footer": {
		"socials": {
			"linkedin": "https://www.linkedin.com/company/99516177/",
			"x": "https://x.com/predotdev",
			"youtube": "https://www.youtube.com/@predotdev",
			"instagram": "https://www.instagram.com/predev.ai/",
			"discord": "https://discord.gg/ejVTRJ6WXS"
		}
	}
}
