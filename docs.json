{
	"$schema": "https://mintlify.com/docs.json",
	"theme": "mint",
	"name": "pre.dev",
	"appearance": {
		"default": "dark"
	},
	"colors": {
		"primary": "#000000",
		"light": "#FFFFFF",
		"dark": "#333333"
	},
	"favicon": "https://pre.dev/favicon.ico",
	"api": {
		"baseUrl": "https://api.pre.dev",
